# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# Google Apps Script — contact form endpoint (get from script.google.com → Deploy)
GOOGLE_SCRIPT_URL=your_google_apps_script_url_here

# Formspree — get your form ID from formspree.io
NEXT_PUBLIC_FORMSPREE_ID=your_form_id_here

# Meta (Facebook + Instagram) — get from developers.facebook.com
# Needed for /job-closeout skill to publish social posts
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_long_lived_page_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# Google Drive API — get from console.cloud.google.com
# Needed for /job-closeout skill to read job folders
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key
